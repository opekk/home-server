# Cloudflare Tunnel token — get this from the Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# GitHub webhook secret — set the same value in your GitHub repo webhook settings
WEBHOOK_SECRET=your-webhook-secret-here

# Tutor file server admin password — needed for upload/delete access
TUTOR_PASSWORD=your-tutor-password-here

# Sensors API key — ESP32 sends this in X-API-Key header to submit readings
SENSORS_API_KEY=your-sensors-api-key-here
