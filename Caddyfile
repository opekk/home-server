{
	admin off
}

:80 {
	@portfolio host portfolio.opekk.dev
	handle @portfolio {
		header {
			X-Content-Type-Options nosniff
			X-Frame-Options DENY
			Referrer-Policy strict-origin-when-cross-origin
		}
		reverse_proxy portfolio:80 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}

	@tutor host tutor.opekk.dev
	handle @tutor {
		reverse_proxy tutor:5000 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}

	@sensors host sensors.opekk.dev
	handle @sensors {
		header {
			X-Content-Type-Options nosniff
			X-Frame-Options DENY
			Referrer-Policy strict-origin-when-cross-origin
		}
		reverse_proxy sensors:8000 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}

	@webhook host webhook.opekk.dev
	handle @webhook {
		reverse_proxy webhook:9000 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}

	handle {
		respond "Not found" 404
	}
}
